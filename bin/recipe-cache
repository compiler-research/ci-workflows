#!/usr/bin/env python3
"""recipe-cache — local CLI for the recipe cache contract.

Same key formula and tarball shape as the GitHub-side actions, with a
file:// backend by default. Lets a developer build, mock, fetch, and
inspect cached recipes on their own machine.

Examples:
  recipe-cache build llvm-asan 22 ubuntu-24.04 x86_64
      Run the recipe's build script and store the result locally.

  recipe-cache pack llvm-asan 22 darwin arm64 --from /path/to/build
      Treat /path/to/build as if a recipe build had produced it
      (mockup mode for testing the cache layer without a 30-min build).

  recipe-cache get llvm-asan 22 ubuntu-24.04 x86_64 --out /tmp/llvm
      Fetch from the local cache and extract under /tmp/llvm/.

  recipe-cache list
      Show every cell currently cached.

Env:
  RECIPE_CACHE_DIR   local cache directory (default: ~/.cache/recipe-cache)
"""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
import tarfile
import tempfile
from datetime import datetime, timezone
from pathlib import Path

# Set up sys.path so we can import the lib modules.
SCRIPT_DIR = Path(__file__).resolve().parent
REPO_ROOT = SCRIPT_DIR.parent
sys.path.insert(0, str(REPO_ROOT / "actions" / "lib"))
sys.path.insert(0, str(REPO_ROOT / "actions" / "setup-recipe"))

import cache_io                              # noqa: E402
from compute_key import compute_key           # noqa: E402


def _cache_dir() -> Path:
    return Path(os.environ.get(
        "RECIPE_CACHE_DIR",
        str(Path.home() / ".cache" / "recipe-cache"),
    ))


def _cache_base() -> str:
    return f"file://{_cache_dir()}"


def _key(recipe: str, version: str, os_: str, arch: str) -> str:
    return compute_key(recipe, version, os_, arch,
                       recipe_root=str(REPO_ROOT / "recipes"),
                       lib_root=str(REPO_ROOT / "actions" / "lib"))


# ---------------------------------------------------------------------------

def cmd_key(args: argparse.Namespace) -> int:
    print(_key(args.recipe, args.version, args.os, args.arch))
    return 0


def cmd_build(args: argparse.Namespace) -> int:
    key = _key(args.recipe, args.version, args.os, args.arch)
    cache_dir = _cache_dir()

    if cache_io.cache_probe(_cache_base(), key):
        print(f"skip: {key} already cached")
        return 0

    cache_dir.mkdir(parents=True, exist_ok=True)
    with tempfile.TemporaryDirectory() as work_str, \
         tempfile.TemporaryDirectory() as out_str:
        env = os.environ | {
            "RECIPE_VERSION": args.version,
            "WORK_DIR":       work_str,
            "OUT_DIR":        out_str,
        }
        recipe_dir = REPO_ROOT / "recipes" / args.recipe
        if (recipe_dir / "build.py").is_file():
            cmd = ["python3", str(recipe_dir / "build.py")]
        elif (recipe_dir / "build.sh").is_file():
            cmd = ["bash", str(recipe_dir / "build.sh")]
        else:
            print(f"recipe-cache: no build.py or build.sh in {recipe_dir}",
                  file=sys.stderr)
            return 2
        subprocess.run(cmd, env=env, check=True)

        cache_io.cache_pack(out_str, key, str(cache_dir))

        # Manifest. Reuse the same module the publish-recipe action does.
        sys.path.insert(0, str(REPO_ROOT / "actions" / "publish-recipe"))
        from build_manifest import build_manifest  # noqa: E402

        manifest = build_manifest(
            args.recipe, args.version, args.os, args.arch, key,
            recipe_root=str(REPO_ROOT / "recipes"),
        )
        (cache_dir / f"{key}.manifest.json").write_text(
            json.dumps(manifest, indent=2) + "\n"
        )

    print(f"built: {cache_dir / (key + '.tar.zst')}")
    return 0


def cmd_pack(args: argparse.Namespace) -> int:
    src = Path(args.source).resolve()
    if not src.is_dir():
        print(f"pack: --from path is not a directory: {src}", file=sys.stderr)
        return 2
    key = _key(args.recipe, args.version, args.os, args.arch)
    cache_dir = _cache_dir()
    cache_dir.mkdir(parents=True, exist_ok=True)

    # Pack the directory as if it were named llvm-project (matches what
    # build.sh would produce). Use tarfile directly with arcname so we
    # don't need to materialise a symlink (which doesn't work cleanly
    # on Windows for non-admins).
    asset_path = cache_dir / f"{key}.tar.zst"
    print(f"::notice::compressing {key}.tar.zst (zstd -3)", flush=True)
    with asset_path.open("wb") as out_f:
        zstd = subprocess.Popen(
            ["zstd", "-3"], stdin=subprocess.PIPE, stdout=out_f,
        )
        try:
            with tarfile.open(fileobj=zstd.stdin, mode="w|") as tar:
                tar.add(src, arcname="llvm-project")
        finally:
            assert zstd.stdin is not None
            zstd.stdin.close()
        rc = zstd.wait()
    if rc != 0:
        print(f"pack: zstd exited {rc}", file=sys.stderr)
        return 1

    # Synthetic manifest — packed assets have less provenance than built
    # ones (no source.commit). Mark them with kind=mockup so list shows it.
    try:
        ci_sha = subprocess.run(
            ["git", "rev-parse", "HEAD"],
            cwd=REPO_ROOT, check=True, capture_output=True, text=True,
        ).stdout.strip()
    except subprocess.CalledProcessError:
        ci_sha = "unknown"
    manifest = {
        "key": key,
        "recipe": args.recipe,
        "version": args.version,
        "platform": {
            "os": args.os, "arch": args.arch,
            "runner_image": "local-mockup", "runner_image_version": "n/a",
        },
        "source": {"repo": "mockup://", "branch": "n/a", "commit": "n/a"},
        "ci_workflows_sha": ci_sha,
        "built_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        "packed_from": str(src),
        "kind": "mockup",
    }
    (cache_dir / f"{key}.manifest.json").write_text(
        json.dumps(manifest, indent=2) + "\n"
    )

    size_kb = asset_path.stat().st_size / 1024
    print(f"packed: {asset_path} ({size_kb:.0f} KiB)")
    return 0


def cmd_get(args: argparse.Namespace) -> int:
    key = _key(args.recipe, args.version, args.os, args.arch)
    out = Path(args.out or os.getcwd())

    if cache_io.cache_probe(_cache_base(), key):
        cache_io.cache_download(_cache_base(), key, str(out))
        print(f"hit: {key} -> {out}")
        return 0

    if args.build_on_miss:
        rc = cmd_build(args)
        if rc != 0:
            return rc
        cache_io.cache_download(_cache_base(), key, str(out))
        print(f"built+got: {key} -> {out}")
        return 0

    print(f"miss: {key} (no asset in {_cache_dir()})", file=sys.stderr)
    print(f"  to populate: recipe-cache build "
          f"{args.recipe} {args.version} {args.os} {args.arch}",
          file=sys.stderr)
    return 1


def cmd_list(_args: argparse.Namespace) -> int:
    cache_dir = _cache_dir()
    if not cache_dir.is_dir():
        print(f"(no cache at {cache_dir})")
        return 0
    any_found = False
    for m in sorted(cache_dir.glob("*.manifest.json")):
        any_found = True
        key = m.name[:-len(".manifest.json")]
        asset = cache_dir / f"{key}.tar.zst"
        size = "?"
        try:
            size_kb = asset.stat().st_size / 1024
            size = f"{size_kb:.0f}K" if size_kb < 1024 else f"{size_kb/1024:.0f}M"
        except OSError:
            pass
        kind = ""
        try:
            data = json.loads(m.read_text())
            kind = data.get("kind", "")
        except (OSError, json.JSONDecodeError):
            pass
        if kind:
            print(f"{key:<72} {size:>6}  [{kind}]")
        else:
            print(f"{key:<72} {size:>6}")
    if not any_found:
        print(f"(empty: {cache_dir})")
    return 0


def cmd_rm(args: argparse.Namespace) -> int:
    cache_dir = _cache_dir()
    asset = cache_dir / f"{args.key}.tar.zst"
    if not asset.is_file():
        print(f"rm: no such key: {args.key}", file=sys.stderr)
        return 2
    asset.unlink()
    manifest = cache_dir / f"{args.key}.manifest.json"
    if manifest.is_file():
        manifest.unlink()
    print(f"removed: {args.key}")
    return 0


# ---------------------------------------------------------------------------

def _build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="recipe-cache")
    sub = p.add_subparsers(dest="cmd", required=True)

    def add_recipe_args(parser):
        parser.add_argument("recipe")
        parser.add_argument("version")
        parser.add_argument("os")
        parser.add_argument("arch")

    p_build = sub.add_parser("build")
    add_recipe_args(p_build)
    p_build.set_defaults(func=cmd_build)

    p_pack = sub.add_parser("pack")
    add_recipe_args(p_pack)
    p_pack.add_argument("--from", dest="source", required=True)
    p_pack.set_defaults(func=cmd_pack)

    p_get = sub.add_parser("get")
    add_recipe_args(p_get)
    p_get.add_argument("--out")
    p_get.add_argument("--build-on-miss", action="store_true")
    p_get.set_defaults(func=cmd_get)

    p_key = sub.add_parser("key")
    add_recipe_args(p_key)
    p_key.set_defaults(func=cmd_key)

    p_list = sub.add_parser("list")
    p_list.set_defaults(func=cmd_list)

    p_rm = sub.add_parser("rm")
    p_rm.add_argument("key")
    p_rm.set_defaults(func=cmd_rm)

    return p


def main(argv: list[str]) -> int:
    args = _build_parser().parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
